{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"globalEnv": ["RESEND_API_KEY"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [
				".next/**",
				"!.next/cache/**",
				"dist/**",
				".svelte-kit/**",
				".output/**",
				".vercel/output/**"
			]
		},
		"check-types": {
			"dependsOn": ["^build", "^check-types"]
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"dev": {
			"persistent": true,
			"cache": false
		},
		"publish-packages": {
			"dependsOn": ["^build"],
			"cache": false
		}
	}
}
