{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"tags": ["-lintignore"],
	"ignoreBinaries": ["tsc"],
	"workspaces": {
		".": {},
		"apps/www": {
			"entry": ["openpolicy.ts", "src/snippets/**", "registry/**"],
			"ignoreDependencies": ["@iconify-json/simple-icons", "vite"],
			"ignoreUnresolved": ["@/components/ui/openpolicy/.+"]
		},
		"apps/docs": {
			"entry": ["source.config.ts"]
		},
		"packages/*": {
			"entry": ["rolldown.config.ts"],
			"ignoreDependencies": ["@openpolicy/tooling"]
		},
		"packages/renderers": {
			"ignoreDependencies": ["@openpolicy/tooling"]
		},
		"examples/*": {
			"entry": ["openpolicy.ts"]
		},
		"examples/tanstack": {
			"entry": ["src/openpolicy.ts"]
		}
	}
}
