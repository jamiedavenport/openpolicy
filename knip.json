{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"tags": ["-lintignore"],
	"ignoreBinaries": ["tsc"],
	"workspaces": {
		".": {},
		"apps/www": {
			"entry": ["openpolicy.ts", "src/snippets/**"],
			"ignoreDependencies": [
				"@iconify-json/simple-icons",
				"vite",
				"@openpolicy/react"
			]
		},
		"apps/docs": {
			"entry": ["source.config.ts"]
		},
		"packages/*": {
			"entry": ["rolldown.config.ts"],
			"ignoreDependencies": ["@openpolicy/tooling"]
		},
		"examples/*": {
			"entry": ["openpolicy.ts"]
		}
	}
}
