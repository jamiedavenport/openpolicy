---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { comparisons } from "../../data/comparisons";
import type { Comparison } from "../../data/comparisons";

export function getStaticPaths() {
	return comparisons.map((c) => ({
		params: { slug: c.slug },
		props: { comparison: c },
	}));
}

interface Props {
	comparison: Comparison;
}

const { comparison } = Astro.props;
const { competitor, tagline, verdict, rows, narrative } = comparison;

const otherComparisons = comparisons.filter((c) => c.slug !== comparison.slug);
---

<BaseLayout
	title={`OpenPolicy vs ${competitor} — OpenPolicy`}
	description={verdict}
	ogUrl={`https://openpolicy.sh/compare/${comparison.slug}`}
>
	<section>
		<h2 class="font-mono font-medium text-xs text-gray-500 mb-2">COMPARE.md</h2>
		<h1 class="font-medium mb-2">{tagline}</h1>
		<p class="text-sm text-gray-500 mb-6">{verdict}</p>

		<div class="overflow-x-auto">
			<table class="w-full border border-gray-200 text-sm border-collapse">
				<thead>
					<tr class="border-b border-gray-200 bg-gray-50">
						<th class="text-left p-3 font-mono text-xs font-medium border-r border-gray-200 w-1/2"></th>
						<th class="text-left p-3 font-mono text-xs font-medium border-r border-gray-200">OpenPolicy</th>
						<th class="text-left p-3 font-mono text-xs font-medium text-gray-500">{competitor}</th>
					</tr>
				</thead>
				<tbody>
					{rows.map((row, i) => (
						<tr class:list={["border-b border-gray-200", i % 2 === 1 ? "bg-gray-50" : "bg-white"]}>
							<td class="p-3 text-xs text-gray-600 border-r border-gray-200">{row.feature}</td>
							<td class="p-3 text-xs font-medium border-r border-gray-200">{row.openpolicy}</td>
							<td class="p-3 text-xs text-gray-500">{row.competitor}</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
	</section>

	<section>
		<h2 class="font-mono font-medium text-xs text-gray-500 mb-4">ANALYSIS.md</h2>
		{narrative.map(({ heading, body }) => (
			<div class="mb-6">
				<h3 class="font-medium text-sm mb-1">{heading}</h3>
				<p class="text-sm text-gray-600">{body}</p>
			</div>
		))}
	</section>

	<section>
		<h2 class="font-mono font-medium text-xs text-gray-500 mb-2">GET-STARTED.md</h2>
		<p class="text-sm mb-4">Try OpenPolicy in your project:</p>
		<div class="font-mono text-sm bg-gray-100 border border-gray-200 p-4 mb-4">
			bunx @openpolicy/cli@latest init
		</div>
		<a
			href="https://docs.openpolicy.sh"
			class="inline-block font-mono text-xs bg-black text-white px-4 py-2 hover:bg-gray-800 transition-colors"
		>
			Read the docs →
		</a>
	</section>

	{otherComparisons.length > 0 && (
		<section>
			<h2 class="font-mono font-medium text-xs text-gray-500 mb-4">OTHER-COMPARISONS.md</h2>
			<div class="grid grid-cols-3 gap-px bg-gray-200 border border-gray-200">
				{otherComparisons.map((c) => (
					<a
						href={`/compare/${c.slug}`}
						class="bg-white p-4 hover:bg-gray-50 transition-colors"
					>
						<p class="font-mono font-medium text-xs mb-1">vs {c.competitor}</p>
						<p class="text-xs text-gray-500">{c.verdict.slice(0, 80)}…</p>
					</a>
				))}
			</div>
		</section>
	)}
</BaseLayout>
