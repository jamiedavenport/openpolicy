---
import { getCollection } from "astro:content";
import BlogList from "../../../components/blog-list.astro";
import TagNav from "../../../components/tag-nav.astro";
import { BLOG_TAGS, type BlogTag } from "../../../content.config";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
	const now = Date.now();
	const all = (await getCollection("blog")).filter(
		(p) => p.data.pubDate.valueOf() <= now,
	);

	const counts = { all: all.length } as Record<BlogTag | "all", number>;
	for (const t of BLOG_TAGS) {
		counts[t] = all.filter((p) => p.data.tags.includes(t)).length;
	}

	return BLOG_TAGS.map((tag) => {
		const posts = all
			.filter((p) => p.data.tags.includes(tag))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

		return { params: { tag }, props: { tag, posts, counts } };
	});
}

type Props = {
	tag: BlogTag;
	posts: Awaited<ReturnType<typeof getCollection<"blog">>>;
	counts: Record<BlogTag | "all", number>;
};

const { tag, posts, counts } = Astro.props as Props;
---

<BaseLayout
  title={`Blog · ${tag} — OpenPolicy`}
  description={`Posts tagged ${tag} from the OpenPolicy team.`}
  ogUrl={`https://openpolicy.sh/blog/tags/${tag}`}
>
  <section>
    <h2 class="font-mono font-medium text-xs text-gray-500 mb-6">
      BLOG.md <span class="text-gray-300">/</span> {tag}
    </h2>

    <TagNav activeTag={tag} counts={counts} />

    {posts.length === 0 ? (
      <p class="font-mono text-xs text-gray-400 py-12">
        no posts tagged <span class="text-gray-700">{tag}</span> — yet.
      </p>
    ) : (
      <BlogList posts={posts} />
    )}
  </section>
</BaseLayout>
