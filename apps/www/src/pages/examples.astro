---
import BaseLayout from "../layouts/BaseLayout.astro";

const examples = [
  {
    name: "Astro",
    description: "Static site using the Astro integration. Generates Markdown and HTML policy files at build time.",
    href: "https://github.com/jamiedavenport/openpolicy/tree/main/examples/landing",
    packages: ["@openpolicy/sdk", "@openpolicy/astro"],
  },
  {
    name: "Next.js",
    description: "Next.js app using the CLI in a prebuild script to generate HTML policy files into public/ before each build.",
    href: "https://github.com/jamiedavenport/openpolicy/tree/main/examples/nextjs",
    packages: ["@openpolicy/sdk", "@openpolicy/cli"],
  },
  {
    name: "TanStack Start",
    description: "Vite + React app using the Vite plugin alongside TanStack Start. Policies are served as dedicated routes.",
    href: "https://github.com/jamiedavenport/openpolicy/tree/main/examples/tanstack",
    packages: ["@openpolicy/sdk", "@openpolicy/vite"],
  },
];
---

<BaseLayout
  title="Examples — OpenPolicy"
  description="Working example projects showing OpenPolicy integrations across Astro, Next.js, and Vite."
  ogUrl="https://openpolicy.sh/examples"
>
  <section>
    <h2 class="font-mono font-medium text-xs text-gray-500 mb-4">EXAMPLES.md</h2>
    <ul class="flex flex-col divide-y divide-gray-200">
      {examples.map((example) => (
        <li>
          <a href={example.href} target="_blank" rel="noopener noreferrer" class="block py-4 hover:bg-gray-50 transition-colors -mx-4 px-4">
            <p class="font-medium mb-1">{example.name}</p>
            <p class="text-sm text-gray-500 mb-2">{example.description}</p>
            <p class="font-mono text-xs text-gray-400">{example.packages.join(" · ")}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
