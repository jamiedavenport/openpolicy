---
import { getCollection } from "astro:content";
import BlogList from "../components/blog-list.astro";
import TagNav from "../components/tag-nav.astro";
import { BLOG_TAGS, type BlogTag } from "../content.config";
import BaseLayout from "../layouts/BaseLayout.astro";

const now = Date.now();
const posts = (await getCollection("blog"))
	.filter((post) => post.data.pubDate.valueOf() <= now)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const counts = { all: posts.length } as Record<BlogTag | "all", number>;
for (const t of BLOG_TAGS) {
	counts[t] = posts.filter((p) => p.data.tags.includes(t)).length;
}
---

<BaseLayout
  title="Blog — OpenPolicy"
  description="Articles on policy-as-code, compliance, and developer tooling from the OpenPolicy team."
  ogUrl="https://openpolicy.sh/blog"
>
  <section>
    <h2 class="font-mono font-medium text-xs text-gray-500 mb-6">BLOG.md</h2>

    <TagNav counts={counts} />

    <BlogList posts={posts} />
  </section>
</BaseLayout>
