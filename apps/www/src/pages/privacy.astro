---
import { compile, expandOpenPolicyConfig } from "@openpolicy/core";
import { renderHTML } from "@openpolicy/renderers";
import openpolicy from "../../openpolicy";
import BaseLayout from "../layouts/BaseLayout.astro";

const policies = expandOpenPolicyConfig(openpolicy);
const privacyPolicy = policies.find((p) => p.type === "privacy");

if (!privacyPolicy) {
	throw new Error("Privacy policy not found in config");
}

const policy = renderHTML(compile(privacyPolicy));
---

<BaseLayout
	title="Privacy Policy — OpenPolicy"
	description="How OpenPolicy collects, uses, and protects your data. Policy-as-code framework for developers."
	ogUrl="https://openpolicy.sh/privacy"
>
	<section>
		<h2 class="font-mono font-medium text-xs text-gray-500 mb-2">PRIVACY.md</h2>
		<article class="prose prose-gray max-w-none">
			<div set:html={policy} />
		</article>
	</section>
</BaseLayout>
