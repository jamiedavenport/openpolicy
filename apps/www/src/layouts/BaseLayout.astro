---
import "../styles/global.css";
import { Font } from "astro:assets";
import Footer from "../components/footer.astro";
import Header from "../components/header.astro";
import Nav from "../components/nav.astro";
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  description: string;
  ogUrl?: string;
  ogImage?: string;
  ctaHref?: string;
  ctaText?: string;
}

const {
  title,
  description,
  ogUrl = "https://openpolicy.sh",
  ogImage = "https://openpolicy.sh/og.png",
  ctaHref = "https://docs.openpolicy.sh",
  ctaText = "Documentation",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <Font cssVariable="--font-geist-mono" preload />
    <slot name="head" />
  </head>
  <body class="bg-gray-50">
    <div class="grid md:grid-cols-3 md:h-svh md:overflow-hidden">
      <div
        class="md:col-span-1 border-b md:border-b-0 md:border-r p-10 lg:p-14 flex flex-col gap-10 border-gray-200"
      >
        <Header />
        <div class="flex-1 flex flex-col justify-center items-start">
          <p class="font-mono font-medium text-xs text-gray-500 mb-2">
            OPEN-SOURCE POLICY-AS-CODE
          </p>
          <p class="text-xl font-medium mb-4">
            The First Policy Framework for Busy Founders and Developers
          </p>
          <div class="flex flex-wrap gap-2">
            <a
              href={ctaHref}
              target="_blank"
              class="px-4 py-2.5 bg-black text-white text-xs font-medium hover:bg-gray-800 transition-colors duration-200"
            >
              {ctaText}
            </a>
            <a
              href="https://github.com/jamiedavenport/openpolicy"
              target="_blank"
              class="px-4 py-2.5 border border-gray-300 text-xs font-medium hover:bg-gray-100 transition-colors duration-200 flex items-center gap-1.5"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="#eab308" stroke="#eab308" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
              Star us on GitHub
            </a>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <a
            href="https://github.com/jamiedavenport/openpolicy"
            target="_blank"
            aria-label="GitHub"
            class="text-gray-400 hover:text-gray-700 transition-colors"
          >
            <Icon name="simple-icons:github" class="w-4 h-4" />
          </a>
          <a
            href="https://x.com/jamiedavenport"
            target="_blank"
            aria-label="X"
            class="text-gray-400 hover:text-gray-700 transition-colors"
          >
            <Icon name="simple-icons:x" class="w-4 h-4" />
          </a>
          <a
            href="https://bsky.app/profile/jamiedavenport.bsky.social"
            target="_blank"
            aria-label="Bluesky"
            class="text-gray-400 hover:text-gray-700 transition-colors"
          >
            <Icon name="simple-icons:bluesky" class="w-4 h-4" />
          </a>
          <a
            href="https://www.linkedin.com/company/openpolicysh"
            target="_blank"
            aria-label="LinkedIn"
            class="text-gray-400 hover:text-gray-700 transition-colors"
          >
            <Icon name="simple-icons:linkedin" class="w-4 h-4" />
          </a>
          <a
            href="mailto:jamie@openpolicy.sh"
            aria-label="Email"
            class="text-gray-400 hover:text-gray-700 transition-colors"
          >
            <Icon name="simple-icons:gmail" class="w-4 h-4" />
          </a>
        </div>
      </div>
      <div class="md:col-span-2 overflow-y-auto bg-white">
        <Nav />
        <div class="flex flex-col gap-10 md:gap-20 p-10 md:p-14 lg:p-20">
          <slot />
          <Footer />
        </div>
      </div>
    </div>
    <script
      is:inline
      src="https://cdn.databuddy.cc/databuddy.js"
      data-client-id="9d48456b-788b-4d22-9f49-a7f31a6424b5"
      crossorigin="anonymous"
      async></script>
  </body>
</html>
