---
import "../styles/global.css";
import { Font } from "astro:assets";
import Footer from "../components/footer.astro";
import Header from "../components/header.astro";
import Nav from "../components/nav.astro";
import { Icon } from "astro-icon/components";
import sdkPkg from "../../../../packages/sdk/package.json";

interface Props {
	title: string;
	description: string;
	ogUrl?: string;
	ogImage?: string;
	ctaHref?: string;
	ctaText?: string;
}

const {
	title,
	description,
	ogUrl = "https://openpolicy.sh",
	ogImage = "https://openpolicy.sh/og.png",
} = Astro.props;

let stars: number | null = null;
try {
	const res = await fetch(
		"https://api.github.com/repos/jamiedavenport/openpolicy",
		{ headers: { Accept: "application/vnd.github+json" } },
	);
	if (res.ok) {
		const data = await res.json();
		stars = data.stargazers_count;
	}
} catch {}

const version = (sdkPkg as { version: string }).version;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content="website" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <Font cssVariable="--font-geist" preload />
    <Font cssVariable="--font-geist-mono" preload />
    <Font cssVariable="--font-instrument-serif" preload />
    <slot name="head" />
  </head>
  <body class="bg-gray-50 md:h-svh md:flex md:flex-col md:overflow-hidden">
    <slot name="banner" />
    <div class="grid md:grid-cols-3 md:flex-1 md:min-h-0 md:overflow-hidden">
      <div
        class="md:col-span-1 border-b md:border-b-0 md:border-r p-10 lg:p-14 flex flex-col gap-10 border-gray-200"
      >
        <Header />
        <div class="flex-1 flex flex-col justify-center items-start">
          <p class="font-mono font-medium text-xs text-gray-500 mb-4 flex items-center gap-2">
            <span class="inline-block w-1 h-1 bg-gray-400"></span>
            COMPLIANCE AS CODE FRAMEWORK
          </p>
          <h1 class="text-3xl lg:text-4xl leading-[1.1] tracking-tight mb-5 max-w-[18ch]">
            <span class="text-gray-900">Consent isn't a checkbox.</span><br/>
            <span class="text-gray-400">It's a system.</span>
          </h1>
          <p class="text-sm text-gray-600 mb-5 max-w-[44ch]">
            OpenPolicy is the consent and compliance layer for your app. Privacy policy, cookie banner, and consent log — generated from your TypeScript, versioned with your code.
          </p>
          <div class="flex flex-wrap gap-2">
            <a
              href="https://cal.eu/jamie-openpolicy/openpolicy-chat-demo"
              target="_blank"
              class="px-4 py-2.5 bg-black text-white text-xs font-medium hover:bg-gray-800 transition-colors duration-200"
            >
              Book a demo
            </a>
            <a
              href="https://github.com/jamiedavenport/openpolicy"
              target="_blank"
              class="group/star text-xs font-medium border border-gray-300 hover:bg-gray-100 transition-colors duration-200 flex items-stretch divide-x divide-gray-300"
            >
              <span class="flex items-center gap-1.5 px-4 py-2.5">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="#eab308" stroke="#eab308" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                Star on GitHub
              </span>
              {stars !== null && (
                <span class="flex items-center px-3 py-2.5 font-mono text-gray-600 tabular-nums">
                  {stars.toLocaleString()}
                </span>
              )}
            </a>
          </div>
        </div>
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-4">
            <a
              href="https://www.linkedin.com/company/openpolicysh"
              target="_blank"
              aria-label="LinkedIn"
              class="text-gray-400 hover:text-gray-700 transition-colors"
            >
              <Icon name="simple-icons:linkedin" class="w-4 h-4" />
            </a>
            <a
              href="mailto:jamie@openpolicy.sh"
              aria-label="Email"
              class="text-gray-400 hover:text-gray-700 transition-colors"
            >
              <Icon name="simple-icons:gmail" class="w-4 h-4" />
            </a>
          </div>
          <p class="font-mono text-[11px] text-gray-400 tabular-nums">
            v{version} <span class="text-gray-300 mx-1">·</span> Apache-2.0
          </p>
        </div>
      </div>
      <div class="md:col-span-2 overflow-y-auto bg-white">
        <Nav />
        <div class="flex flex-col gap-14 md:gap-24 p-10 md:p-14">
          <slot />
          <Footer />
        </div>
      </div>
    </div>
    <script
      is:inline
      src="https://cdn.databuddy.cc/databuddy.js"
      data-client-id="9d48456b-788b-4d22-9f49-a7f31a6424b5"
      crossorigin="anonymous"
      async></script>
    <script>
      import "../lib/offstage";
    </script>
  </body>
</html>
