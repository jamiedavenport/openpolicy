---
import { BLOG_TAGS, type BlogTag } from "../content.config";

type Props = {
	activeTag?: BlogTag;
	counts: Record<BlogTag | "all", number>;
};

const { activeTag, counts } = Astro.props;

const baseLink = "transition-colors";
const inactive = "text-gray-400 hover:text-gray-900";
const active = "text-gray-900 underline underline-offset-4 decoration-gray-300";
---

<nav class="flex flex-wrap gap-x-4 gap-y-2 mb-10 font-mono text-xs">
  <a
    href="/blog"
    class:list={[baseLink, activeTag ? inactive : active]}
  >
    all <span class="text-gray-300 tabular-nums">{counts.all}</span>
  </a>
  {BLOG_TAGS.map((t) => (
    <a
      href={`/blog/tags/${t}`}
      class:list={[baseLink, activeTag === t ? active : inactive]}
    >
      {t} <span class="text-gray-300 tabular-nums">{counts[t] ?? 0}</span>
    </a>
  ))}
</nav>
