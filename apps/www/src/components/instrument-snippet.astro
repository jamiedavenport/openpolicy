---
import { Code } from "astro:components";
import instrumentTs from "../snippets/instrument.ts?raw";

const ERROR_MESSAGE = "Name must be declared or explicitly ignored";
const ERROR_LINES = new Set([11, 12, 13, 14]);

const transformer = {
  name: "mark-third-object",
  line(node: { properties?: Record<string, unknown> }, lineNum: number) {
    if (!ERROR_LINES.has(lineNum)) return;
    const props = (node.properties ??= {}) as { class?: string };
    props.class = `${props.class ? `${props.class} ` : ""}op-error-line`;
  },
};
---

<div class="border border-gray-200 overflow-hidden bg-white">
  <div class="flex items-center bg-gray-50 border-b border-gray-200 h-10 pl-3 pr-3.5 gap-3">
    <div class="flex items-center gap-1.5 shrink-0" aria-hidden="true">
      <span class="op-light op-light-red"></span>
      <span class="op-light op-light-yellow"></span>
      <span class="op-light op-light-green"></span>
    </div>
    <div
      class="self-end flex items-center gap-1.5 px-2.5 py-1 bg-white border border-gray-200 -mb-px border-b-white rounded-t-sm min-w-0"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="11"
        height="11"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-blue-500 shrink-0"
        aria-hidden="true"
      >
        <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path>
        <path d="M14 2v4a2 2 0 0 0 2 2h4"></path>
      </svg>
      <span class="font-mono text-xs text-gray-700 truncate">src/actions/create-user.ts</span>
    </div>
    <span class="ml-auto font-mono text-[10px] text-gray-400 tracking-wider uppercase shrink-0">ts</span>
  </div>

  <div class="op-code-body op-instrument-snippet">
    <Code code={instrumentTs} lang="ts" theme="github-light" transformers={[transformer]} />
    <div class="op-error-tooltip" role="tooltip" aria-hidden="true">
      <svg
        width="12"
        height="12"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.4"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="op-error-tooltip-icon shrink-0"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" x2="12" y1="8" y2="12"></line>
        <line x1="12" x2="12.01" y1="16" y2="16"></line>
      </svg>
      <span>{ERROR_MESSAGE}</span>
    </div>
  </div>
</div>

<style is:global>
  .op-instrument-snippet {
    position: relative;
  }
  .op-instrument-snippet .op-error-line {
    display: inline-block;
    width: 100%;
    background-color: rgba(254, 226, 226, 0.45);
    text-decoration: underline wavy #dc2626;
    text-decoration-skip-ink: none;
    text-underline-offset: 3px;
    cursor: help;
  }
  .op-instrument-snippet .op-error-tooltip {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    max-width: 18rem;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    background: #fff;
    border: 1px solid #fca5a5;
    color: #991b1b;
    padding: 0.5rem 0.625rem;
    font-family:
      ui-monospace,
      SFMono-Regular,
      Menlo,
      Monaco,
      Consolas,
      monospace;
    font-size: 0.6875rem;
    line-height: 1.45;
    border-radius: 6px;
    box-shadow: 0 10px 24px -8px rgba(0, 0, 0, 0.18);
    opacity: 0;
    transform: translateY(-4px);
    pointer-events: none;
    transition:
      opacity 150ms ease,
      transform 150ms ease;
    z-index: 10;
  }
  .op-instrument-snippet .op-error-tooltip-icon {
    color: #dc2626;
    margin-top: 1px;
  }
  .op-instrument-snippet:has(.op-error-line:hover) .op-error-tooltip {
    opacity: 1;
    transform: translateY(0);
  }
</style>
