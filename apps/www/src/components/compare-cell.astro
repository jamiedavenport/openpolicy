---
interface Props {
  value: string;
  emphasize?: boolean;
}

const { value, emphasize = false } = Astro.props;

const kind: "check" | "x" | "dash" | "text" =
  value === "✓"
    ? "check"
    : value === "✗"
      ? "x"
      : value === "—"
        ? "dash"
        : "text";
---

{kind === "check" && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class:list={["inline", emphasize ? "text-gray-900" : "text-gray-400"]}
    aria-label="Yes"
  >
    <polyline points="20 6 9 17 4 12"></polyline>
  </svg>
)}
{kind === "x" && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="inline text-gray-300"
    aria-label="No"
  >
    <path d="M18 6 6 18"></path>
    <path d="m6 6 12 12"></path>
  </svg>
)}
{kind === "dash" && <span class="text-gray-300">—</span>}
{kind === "text" && (
  <span class:list={emphasize ? "font-medium" : "text-gray-500"}>{value}</span>
)}
