---
import { Code } from "astro:components";
import { compile, expandOpenPolicyConfig } from "@openpolicy/core";
import type { DocumentSection } from "@openpolicy/core";
import { renderHTML } from "@openpolicy/renderers";
import { scenes } from "../lib/demo-scenes";

type CompiledScene = {
  label: string;
  code: string;
  addedLines: number[];
  sections: DocumentSection[];
};

function compileScene(config: (typeof scenes)[number]["config"]): DocumentSection[] {
  const inputs = expandOpenPolicyConfig(config);
  const privacy = inputs.find((i) => i.type === "privacy");
  if (!privacy) return [];
  return compile(privacy).sections;
}

function renderSectionHTML(section: DocumentSection): string {
  return renderHTML({
    type: "document",
    policyType: "privacy",
    sections: [section],
  });
}

const compiled: CompiledScene[] = scenes.map((s) => ({
  label: s.label,
  code: s.code,
  addedLines: s.addedLines,
  sections: compileScene(s.config),
}));
---

<div class="op-demo border border-gray-200 overflow-hidden bg-white" data-demo-stack>
  <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-gray-200">
    <!-- left pane: code editor -->
    <div class="flex flex-col min-w-0">
      <div class="op-demo-chrome op-demo-chrome-editor flex items-center bg-gray-50 border-b border-gray-200 h-10 pl-3 pr-3.5 gap-3">
        <div class="op-traffic-lights flex items-center gap-1.5 shrink-0" aria-hidden="true">
          <span class="op-light op-light-red"></span>
          <span class="op-light op-light-yellow"></span>
          <span class="op-light op-light-green"></span>
        </div>
        <div class="op-editor-tab self-end flex items-center gap-1.5 px-2.5 py-1 bg-white border border-gray-200 -mb-px border-b-white rounded-t-sm min-w-0">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="11"
            height="11"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-blue-500 shrink-0"
            aria-hidden="true"
          >
            <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path>
            <path d="M14 2v4a2 2 0 0 0 2 2h4"></path>
          </svg>
          <span class="font-mono text-xs text-gray-700 truncate">openpolicy.ts</span>
        </div>
        <span class="ml-auto font-mono text-[10px] text-gray-400 tracking-wider uppercase shrink-0">ts</span>
      </div>
      <div class="op-demo-col op-demo-code op-code-body">
        {
          compiled.map((s, i) => (
            <div
              class="op-demo-scene"
              data-scene={i}
              data-pane="code"
              data-added-lines={s.addedLines.join(",")}
            >
              <Code code={s.code} lang="ts" theme="github-light" />
            </div>
          ))
        }
      </div>
    </div>

    <!-- right pane: browser -->
    <div class="flex flex-col min-w-0">
      <div class="op-demo-chrome op-demo-chrome-browser flex items-center bg-gray-50 border-b border-gray-200 h-10 px-3 gap-2.5">
        <div class="flex items-center gap-1 shrink-0 text-gray-300" aria-hidden="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </div>
        <div class="flex-1 flex items-center gap-1.5 px-2 py-1 bg-white border border-gray-200 rounded-sm min-w-0">
          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-600 shrink-0" aria-hidden="true">
            <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
          <span class="font-mono text-[11px] text-gray-700 truncate">acme.com/privacy</span>
        </div>
        <span class="font-mono text-[10px] text-gray-400 tracking-wider uppercase shrink-0">live</span>
      </div>
      <div class="op-demo-col op-demo-policy">
        {
          compiled.map((s, i) => (
            <div class="op-demo-scene policy-pane" data-scene={i} data-pane="policy">
              {s.sections.map((sec) => (
                <section class="policy-section" data-section-id={sec.id}>
                  <Fragment set:html={renderSectionHTML(sec)} />
                </section>
              ))}
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div
    class="op-demo-controls border-t border-gray-200 grid divide-x divide-gray-200"
    style={`grid-template-columns: repeat(${compiled.length}, minmax(0, 1fr))`}
    data-demo-controls
  >
    {
      compiled.map((s, i) => (
        <button
          type="button"
          class="op-demo-btn relative overflow-hidden font-mono text-[10px] tracking-wide uppercase py-2.5 text-gray-400 hover:text-gray-900 transition-colors"
          data-scene-btn={i}
          aria-label={`Show scene: ${s.label}`}
        >
          <span
            class="op-demo-btn-fill absolute inset-0 bg-gray-900/[0.06]"
            data-progress-segment={i}
            aria-hidden="true"
          />
          <span class="relative">{s.label}</span>
        </button>
      ))
    }
  </div>
</div>

<style is:global>
  .op-demo .op-demo-btn-fill {
    transform: scaleX(0);
    transform-origin: left center;
    will-change: transform;
  }
  .op-demo .op-demo-col {
    position: relative;
    min-height: 480px;
  }
  .op-demo .op-demo-scene {
    position: absolute;
    inset: 0;
    opacity: 0;
    pointer-events: none;
    overflow-y: auto;
  }
  .op-demo .op-demo-scene[data-active] {
    opacity: 1;
    pointer-events: auto;
  }
  .op-demo .op-code-body pre.astro-code {
    margin: 0;
    padding: 1rem;
    font-size: 0.8125rem;
    line-height: 1.6;
    background: transparent !important;
  }
  .op-demo .op-code-body .line {
    display: inline-block;
    width: 100%;
    transition: background-color 600ms ease;
  }
  .op-demo .op-code-body .line.diff-added {
    background-color: rgba(16, 185, 129, 0.18);
    box-shadow: inset 2px 0 0 rgb(16, 185, 129);
  }

  .op-demo .policy-pane {
    padding: 1rem 1.25rem;
    font-size: 0.8125rem;
    line-height: 1.55;
    color: #374151;
  }
  .op-demo .policy-pane .policy-section {
    margin-bottom: 0.5rem;
    padding: 0.4rem 0.5rem;
    border-radius: 2px;
  }
  .op-demo .policy-pane h2 {
    font-size: 0.95rem;
    font-weight: 600;
    color: #111827;
    margin: 0.25rem 0 0.4rem;
  }
  .op-demo .policy-pane h3 {
    font-size: 0.825rem;
    font-weight: 600;
    color: #1f2937;
    margin: 0.6rem 0 0.2rem;
  }
  .op-demo .policy-pane p {
    margin: 0.4rem 0;
  }
  .op-demo .policy-pane ul,
  .op-demo .policy-pane ol {
    margin: 0.4rem 0 0.4rem 1.1rem;
  }
  .op-demo .policy-pane ul {
    list-style: disc;
  }
  .op-demo .policy-pane ol {
    list-style: decimal;
  }
  .op-demo .policy-pane li {
    margin: 0.15rem 0;
  }
  .op-demo .policy-pane a {
    color: #2563eb;
    text-decoration: underline;
  }
  .op-demo .policy-pane strong {
    color: #111827;
    font-weight: 600;
  }

  .op-demo .op-demo-btn {
    cursor: pointer;
  }
  .op-demo .op-demo-btn[data-active] {
    color: #111827;
  }
  .op-demo .op-demo-btn[data-visited] {
    color: #374151;
  }

  @media (prefers-reduced-motion: reduce) {
    .op-demo .op-demo-scene {
      transition: none !important;
    }
    .op-demo .op-code-body .line.diff-added {
      background-color: transparent;
      box-shadow: none;
    }
  }
</style>

<script>
  import { animate } from "motion/mini";

  const stack = document.querySelector<HTMLElement>("[data-demo-stack]");
  if (!stack) {
    // nothing to do
  } else {
    const codeScenes = stack.querySelectorAll<HTMLElement>(
      ".op-demo-code > .op-demo-scene",
    );
    const policyScenes = stack.querySelectorAll<HTMLElement>(
      ".op-demo-policy > .op-demo-scene",
    );
    const buttons = stack.querySelectorAll<HTMLButtonElement>(
      "[data-demo-controls] button[data-scene-btn]",
    );
    const segments = stack.querySelectorAll<HTMLElement>("[data-progress-segment]");
    const DWELL_MS = 4200;
    const total = codeScenes.length;
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let current = 0;
    let dwellTimer: ReturnType<typeof setTimeout> | null = null;
    let dwellAnim: ReturnType<typeof animate> | null = null;
    let dwellStartedAt = 0;
    let dwellAccumulated = 0;
    let paused = false;
    let inView = false;

    function setActive(idx: number, opts: { animated: boolean }) {
      if (idx === current) return;
      const prevCode = codeScenes[current];
      const nextCode = codeScenes[idx];
      const prevPolicy = policyScenes[current];
      const nextPolicy = policyScenes[idx];
      if (!prevCode || !nextCode || !prevPolicy || !nextPolicy) return;

      const prevIds = new Set(
        Array.from(
          prevPolicy.querySelectorAll<HTMLElement>("[data-section-id]"),
        ).map((n) => n.dataset.sectionId),
      );
      const newSections = Array.from(
        nextPolicy.querySelectorAll<HTMLElement>("[data-section-id]"),
      ).filter((n) => !prevIds.has(n.dataset.sectionId));

      prevCode.removeAttribute("data-active");
      prevPolicy.removeAttribute("data-active");
      nextCode.setAttribute("data-active", "");
      nextPolicy.setAttribute("data-active", "");
      buttons.forEach((b, i) => {
        if (i === idx) b.setAttribute("data-active", "");
        else b.removeAttribute("data-active");
      });

      if (opts.animated && !reduced) {
        animate(prevCode, { opacity: 0 }, { duration: 0.18 });
        animate(nextCode, { opacity: 1 }, { duration: 0.28 });
        animate(prevPolicy, { opacity: 0 }, { duration: 0.18 });
        animate(nextPolicy, { opacity: 1 }, { duration: 0.28 });

        const addedRaw = nextCode.dataset.addedLines || "";
        const addedLines = addedRaw
          .split(",")
          .filter(Boolean)
          .map((s) => Number(s));
        if (addedLines.length) {
          const lines = nextCode.querySelectorAll<HTMLElement>(
            "pre.astro-code .line",
          );
          addedLines.forEach((i) => {
            const line = lines[i];
            if (!line) return;
            line.classList.add("diff-added");
            setTimeout(() => line.classList.remove("diff-added"), 1400);
          });
        }

        newSections.forEach((sec) => {
          animate(
            sec,
            {
              backgroundColor: [
                "rgba(254, 243, 199, 0.75)",
                "rgba(254, 243, 199, 0)",
              ],
            },
            { duration: 1.4, ease: "easeOut" },
          );
        });
      }

      current = idx;
    }

    function resetSegments() {
      segments.forEach((seg, i) => {
        seg.style.transform = i < current ? "scaleX(1)" : "scaleX(0)";
      });
      buttons.forEach((b, i) => {
        if (i < current) b.setAttribute("data-visited", "");
        else b.removeAttribute("data-visited");
      });
    }

    function clearDwell() {
      if (dwellTimer) clearTimeout(dwellTimer);
      dwellTimer = null;
      if (dwellAnim) {
        try {
          dwellAnim.cancel();
        } catch {}
        dwellAnim = null;
      }
    }

    function startDwell() {
      clearDwell();
      if (paused || !inView) return;
      const remaining = Math.max(0, DWELL_MS - dwellAccumulated);
      dwellStartedAt = Date.now();
      const seg = segments[current];
      if (seg && !reduced) {
        const fromScale = dwellAccumulated / DWELL_MS;
        dwellAnim = animate(
          seg,
          { transform: [`scaleX(${fromScale})`, "scaleX(1)"] },
          { duration: remaining / 1000, ease: "linear" },
        );
      } else if (seg) {
        seg.style.transform = "scaleX(1)";
      }
      dwellTimer = setTimeout(() => {
        dwellAccumulated = 0;
        const next = (current + 1) % total;
        setActive(next, { animated: true });
        resetSegments();
        startDwell();
      }, remaining);
    }

    function pauseDwell() {
      if (dwellTimer) clearTimeout(dwellTimer);
      dwellTimer = null;
      if (dwellAnim) dwellAnim.pause();
      if (dwellStartedAt > 0) {
        dwellAccumulated = Math.min(
          DWELL_MS,
          dwellAccumulated + (Date.now() - dwellStartedAt),
        );
        dwellStartedAt = 0;
      }
    }

    codeScenes[0]?.setAttribute("data-active", "");
    policyScenes[0]?.setAttribute("data-active", "");
    buttons[0]?.setAttribute("data-active", "");
    resetSegments();

    function jumpTo(idx: number) {
      if (idx === current) return;
      dwellAccumulated = 0;
      setActive(idx, { animated: true });
      resetSegments();
      startDwell();
    }

    buttons.forEach((btn, i) => {
      btn.addEventListener("click", () => jumpTo(i));
    });

    stack.addEventListener("mouseenter", () => {
      paused = true;
      pauseDwell();
    });
    stack.addEventListener("mouseleave", () => {
      paused = false;
      startDwell();
    });

    const observer = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            inView = true;
            startDwell();
          } else {
            inView = false;
            pauseDwell();
          }
        }
      },
      { threshold: 0.25 },
    );
    observer.observe(stack);
  }
</script>
