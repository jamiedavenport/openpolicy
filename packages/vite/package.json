{
	"name": "@openpolicy/vite",
	"version": "0.0.8",
	"type": "module",
	"description": "Vite plugin for compiling OpenPolicy privacy policy documents at build time",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiedavenport/openpolicy",
		"directory": "packages/vite"
	},
	"keywords": [
		"vite-plugin"
	],
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": {
