{
	"name": "@openpolicy/vite",
	"version": "0.0.24",
	"type": "module",
	"description": "Vite plugin that scans source files for @openpolicy/sdk collecting()/thirdParty() calls and populates the auto-collected registry at build time",
	"license": "GPL-3.0-only",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiedavenport/openpolicy",
		"directory": "packages/vite"
	},
	"keywords": [
		"vite-plugin",
		"openpolicy",
		"privacy-policy"
	],
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"dev": "rolldown -c --watch",
		"build": "rolldown -c",
		"check-types": "tsc --noEmit",
		"test": "bun test"
	},
	"peerDependencies": {
		"vite": ">=4.0.0"
	},
	"dependencies": {
		"oxc-parser": "^0.124.0"
	},
	"devDependencies": {
		"@openpolicy/sdk": "workspace:*",
		"@openpolicy/tooling": "workspace:*",
		"vite": "catalog:"
	}
}
